        { "fieldname": "qte_theorique", "label": "Qte Théorique (Système)", "fieldtype": "Float", "read_only": 1, "in_list_view": 1, "columns": 1, "description": "Remplie auto depuis Bin ERPNext" },
        { "fieldname": "qte_comptee", "label": "Qte Comptée", "fieldtype": "Float", "reqd": 1, "in_list_view": 1, "columns": 1 },
