   "fieldtype": "Data",
   "hidden": 1,
   "read_only": 1
  },
  {
   "fieldname": "amended_from",
   "label": "Modifié depuis",
   "fieldtype": "Link",
   "options": "Planning Conge",
   "no_copy": 1,
   "print_hide": 1,
   "read_only": 1
  }
 ],
