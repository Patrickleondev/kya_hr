{
 "name": "Inventaire KYA",
 "module": "KYA HR",
 "doctype": "DocType",
 "is_submittable": 1,
 "custom": 1,
 "autoname": "format:INV-KYA-{YYYY}-{#####}",
 "title_field": "objet",
 "search_fields": "objet, date_inventaire, responsable_nom, statut",
 "track_changes": 1,
 "fields": [
  {
   "fieldname": "section_general",
   "label": "Informations Générales",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "objet",
   "label": "Objet / Libellé de l'Inventaire",
   "fieldtype": "Small Text",
   "reqd": 1,
   "in_list_view": 1
  },
  {
   "fieldname": "date_inventaire",
   "label": "Date d'Inventaire",
   "fieldtype": "Date",
   "reqd": 1,
   "default": "Today",
   "in_list_view": 1,
   "in_standard_filter": 1
  },
  {
   "fieldname": "col_ref",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "reference",
   "label": "Référence",
   "fieldtype": "Data",
   "default": "KYA-STK-INV-V01",
   "read_only": 1
  },
  {
   "fieldname": "type_inventaire",
   "label": "Type",
   "fieldtype": "Select",
   "options": "Complet\nPartiel\nCyclique",
   "default": "Partiel",
   "in_list_view": 1
  },
  {
   "fieldname": "warehouse_filter",
   "label": "Magasin concerné",
   "fieldtype": "Link",
   "options": "Warehouse",
   "description": "Laisser vide pour inventaire multi-magasins"
  },
  {
   "fieldname": "section_items",
   "label": "Lignes d'Inventaire",
   "fieldtype": "Section Break",
   "description": "Utilisez le bouton 'Charger Articles' pour pré-remplir depuis le stock actuel"
  },
  {
   "fieldname": "items",
   "label": "Articles",
   "fieldtype": "Table",
   "options": "Inventaire KYA Item",
   "reqd": 1
  },
  {
   "fieldname": "section_totaux",
   "label": "Synthèse",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "total_lignes",
   "label": "Nb lignes",
   "fieldtype": "Int",
   "read_only": 1
  },
  {
   "fieldname": "lignes_avec_ecart",
   "label": "Lignes avec écart",
   "fieldtype": "Int",
   "read_only": 1
  },
  {
   "fieldname": "col_totaux",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "valeur_ecart_total",
   "label": "Valeur totale de l'écart (XOF)",
   "fieldtype": "Currency",
   "read_only": 1
  },
  {
   "fieldname": "section_signatures",
   "label": "Validations",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "responsable_nom",
   "label": "Responsable Inventaire",
   "fieldtype": "Data",
   "reqd": 1
  },
  {
   "fieldname": "responsable_date",
   "label": "Date",
   "fieldtype": "Date",
   "default": "Today"
  },
  {
   "fieldname": "signature_responsable",
   "label": "Signature Responsable",
   "fieldtype": "Signature"
  },
  {
   "fieldname": "col_sig",
   "fieldtype": "Column Break"
  },
  {
   "fieldname": "magasin_nom",
   "label": "Responsable Magasin",
   "fieldtype": "Data",
   "read_only": 1
  },
  {
   "fieldname": "magasin_date",
   "label": "Date Magasin",
   "fieldtype": "Date",
   "read_only": 1
  },
  {
   "fieldname": "signature_magasin",
   "label": "Signature Magasin",
   "fieldtype": "Signature",
   "read_only": 1
  },
  {
   "fieldname": "section_statut",
   "label": "Statut",
   "fieldtype": "Section Break"
  },
  {
   "fieldname": "statut",
   "label": "Statut",
   "fieldtype": "Select",
   "options": "Brouillon\nEn attente Magasin\nApprouvé\nRejeté",
   "default": "Brouillon",
   "in_list_view": 1,
   "in_standard_filter": 1,
   "read_only": 1
  },
  {
   "fieldname": "workflow_state",
   "label": "État du Flux",
   "fieldtype": "Data",
   "hidden": 1,
   "read_only": 1
  },
  {
   "fieldname": "stock_reconciliation",
   "label": "Stock Reconciliation générée",
   "fieldtype": "Link",
   "options": "Stock Reconciliation",
   "read_only": 1,
   "print_hide": 1
  },
  {
   "fieldname": "amended_from",
   "label": "Modifié depuis",
   "fieldtype": "Link",
   "options": "Inventaire KYA",
   "no_copy": 1,
   "print_hide": 1,
   "read_only": 1
  }
 ],
 "permissions": [
  {
   "role": "System Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "delete": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1,
   "print": 1,
   "email": 1,
   "export": 1,
   "report": 1,
   "share": 1
  },
  {
   "role": "Stock Manager",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1,
   "cancel": 1,
   "amend": 1
  },
  {
   "role": "Stock User",
   "read": 1,
   "write": 1,
   "create": 1,
   "submit": 1
  },
  {
   "role": "Employee",
   "read": 1,
   "if_owner": 1
  }
 ]
}
