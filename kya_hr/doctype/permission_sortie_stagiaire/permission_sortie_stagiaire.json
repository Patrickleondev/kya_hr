{
    "name": "Permission Sortie Stagiaire",
    "module": "KYA HR",
    "doctype": "DocType",
    "is_submittable": 1,
    "custom": 1,
    "autoname": "format:PSS-{YYYY}-{#####}",
    "title_field": "employee_name",
    "search_fields": "employee_name, date_sortie, statut",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "section_stagiaire",
            "label": "Informations Stagiaire",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "employee",
            "label": "Stagiaire (Employ\u00e9)",
            "fieldtype": "Link",
            "options": "Employee",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "employee_name",
            "label": "Nom",
            "fieldtype": "Data",
            "fetch_from": "employee.employee_name",
            "read_only": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "col_dept",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "department",
            "label": "D\u00e9partement",
            "fieldtype": "Link",
            "options": "Department",
            "fetch_from": "employee.department",
            "read_only": 1
        },
        {
            "fieldname": "company",
            "label": "Soci\u00e9t\u00e9",
            "fieldtype": "Link",
            "options": "Company",
            "fetch_from": "employee.company",
            "read_only": 1,
            "hidden": 1
        },
        {
            "fieldname": "section_sortie",
            "label": "D\u00e9tails de la Sortie",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "date_sortie",
            "label": "Date de Sortie",
            "fieldtype": "Date",
            "reqd": 1,
            "default": "Today",
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "heure_depart",
            "label": "Heure de D\u00e9part",
            "fieldtype": "Time",
            "reqd": 1
        },
        {
            "fieldname": "col_retour",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "heure_retour",
            "label": "Heure de Retour Pr\u00e9vue",
            "fieldtype": "Time"
        },
        {
            "fieldname": "duree",
            "label": "Dur\u00e9e Estim\u00e9e",
            "fieldtype": "Data",
            "read_only": 1,
            "description": "Calcul\u00e9e automatiquement"
        },
        {
            "fieldname": "section_motif",
            "label": "Motif",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "motif",
            "label": "Motif de la Sortie",
            "fieldtype": "Small Text",
            "reqd": 1
        },
        {
            "fieldname": "justificatif",
            "label": "Pi\u00e8ce Justificative",
            "fieldtype": "Attach",
