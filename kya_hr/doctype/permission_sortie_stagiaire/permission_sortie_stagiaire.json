{
    "name": "Permission Sortie Stagiaire",
    "module": "KYA HR",
    "doctype": "DocType",
    "is_submittable": 1,
    "custom": 1,
    "autoname": "format:PSS-{YYYY}-{#####}",
    "title_field": "employee",
    "fields": [
        {
            "fieldname": "employee",
            "label": "Stagiaire (Employ\u00e9)",
            "fieldtype": "Link",
            "options": "Employee",
