            "in_standard_filter": 1,
            "read_only": 1
        },
        {
            "fieldname": "col_approbation",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "workflow_state",
            "label": "\u00c9tat du Flux",
            "fieldtype": "Data",
            "hidden": 1,
            "read_only": 1
        },
        {
            "fieldname": "amended_from",
            "label": "Modifi\u00e9 depuis",
            "fieldtype": "Link",
            "options": "Permission Sortie Stagiaire",
            "no_copy": 1,
            "print_hide": 1,
