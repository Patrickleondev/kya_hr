        },
        {
            "fieldname": "date_sortie",
            "label": "Date de Sortie",
            "fieldtype": "Date",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "heure_depart",
            "label": "Heure de D\u00e9part",
            "fieldtype": "Time",
            "reqd": 1
        },
        {
            "fieldname": "heure_retour",
            "label": "Heure de Retour Pr\u00e9vue",
            "fieldtype": "Time"
        },
        {
            "fieldname": "motif",
            "label": "Motif",
            "fieldtype": "Small Text",
            "reqd": 1
        },
        {
            "fieldname": "statut",
            "label": "Statut",
