{
    "name": "Demande Achat KYA",
    "module": "KYA HR",
    "doctype": "DocType",
    "is_submittable": 1,
    "custom": 1,
    "autoname": "format:DA-{YYYY}-{#####}",
    "title_field": "objet",
    "search_fields": "objet, employee_name, statut",
    "track_changes": 1,
    "fields": [
        {
            "fieldname": "section_demandeur",
            "label": "Demandeur",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "employee",
            "label": "Employ\u00e9 Demandeur",
            "fieldtype": "Link",
            "options": "Employee",
            "reqd": 1,
            "in_list_view": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "employee_name",
            "label": "Nom",
            "fieldtype": "Data",
            "fetch_from": "employee.employee_name",
            "read_only": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "col_demandeur",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "department",
            "label": "D\u00e9partement",
            "fieldtype": "Link",
            "options": "Department",
            "fetch_from": "employee.department",
            "read_only": 1,
            "in_standard_filter": 1
        },
        {
            "fieldname": "date_demande",
            "label": "Date de Demande",
            "fieldtype": "Date",
            "reqd": 1,
            "default": "Today",
            "in_list_view": 1
        },
        {
            "fieldname": "company",
            "label": "Soci\u00e9t\u00e9",
            "fieldtype": "Link",
            "options": "Company",
            "fetch_from": "employee.company",
            "read_only": 1,
            "hidden": 1
        },
        {
            "fieldname": "section_details",
            "label": "D\u00e9tails de la Demande",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "objet",
            "label": "Objet / Motif",
            "fieldtype": "Data",
            "reqd": 1,
            "in_list_view": 1
        },
        {
            "fieldname": "urgence",
            "label": "Niveau d\u2019Urgence",
            "fieldtype": "Select",
            "options": "Normal\nUrgent\nTr\u00e8s Urgent",
            "default": "Normal",
            "in_standard_filter": 1
        },
        {
            "fieldname": "justification",
            "label": "Justification",
            "fieldtype": "Small Text"
        },
        {
            "fieldname": "section_items",
            "label": "Articles Demand\u00e9s",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "items",
            "label": "Articles",
            "fieldtype": "Table",
            "options": "Demande Achat Item",
            "reqd": 1
        },
        {
            "fieldname": "section_total",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "montant_total",
            "label": "Montant Total (XOF)",
            "fieldtype": "Currency",
            "read_only": 1,
            "in_list_view": 1,
            "bold": 1,
            "options": "Company:company:default_currency"
        },
        {
            "fieldname": "palier",
            "label": "Palier d\u2019Approbation",
            "fieldtype": "Data",
            "read_only": 1,
            "description": "D\u00e9termin\u00e9 automatiquement selon le montant"
        },
        {
            "fieldname": "section_signatures",
            "label": "Approbations & Signatures",
            "fieldtype": "Section Break",
            "description": "Chaque approbateur signe \u00e0 son niveau"
        },
        {
            "fieldname": "col_sig_demandeur",
            "fieldtype": "Column Break",
            "label": "Demandeur"
        },
        {
            "fieldname": "signature_demandeur",
            "label": "Signature Demandeur",
            "fieldtype": "Signature"
        },
        {
            "fieldname": "signataire_demandeur",
            "label": "Nom Signataire",
            "fieldtype": "Data",
            "read_only": 1
        },
        {
            "fieldname": "date_signature_demandeur",
            "label": "Date Signature",
            "fieldtype": "Date",
            "read_only": 1
        },
        {
            "fieldname": "col_sig_chef",
            "fieldtype": "Column Break",
            "label": "Chef de Service"
        },
        {
            "fieldname": "signature_chef",
            "label": "Signature Chef",
            "fieldtype": "Signature",
            "read_only": 1
        },
        {
            "fieldname": "signataire_chef",
            "label": "Nom Chef",
            "fieldtype": "Data",
            "read_only": 1
        },
        {
            "fieldname": "date_signature_chef",
            "label": "Date Signature Chef",
            "fieldtype": "Date",
            "read_only": 1
        },
        {
            "fieldname": "section_signatures_2",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "col_sig_dga",
            "fieldtype": "Column Break",
            "label": "DGA / Responsable Achats"
        },
        {
            "fieldname": "signature_dga",
            "label": "Signature DGA",
            "fieldtype": "Signature",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 100000"
        },
        {
            "fieldname": "signataire_dga",
            "label": "Nom DGA",
            "fieldtype": "Data",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 100000"
        },
        {
            "fieldname": "date_signature_dga",
            "label": "Date Signature DGA",
            "fieldtype": "Date",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 100000"
        },
        {
            "fieldname": "col_sig_dg",
            "fieldtype": "Column Break",
            "label": "Directeur G\u00e9n\u00e9ral"
        },
        {
            "fieldname": "signature_dg",
            "label": "Signature DG",
            "fieldtype": "Signature",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 2000000"
        },
        {
            "fieldname": "signataire_dg",
            "label": "Nom DG",
            "fieldtype": "Data",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 2000000"
        },
        {
            "fieldname": "date_signature_dg",
            "label": "Date Signature DG",
            "fieldtype": "Date",
            "read_only": 1,
            "depends_on": "eval:doc.montant_total >= 2000000"
        },
        {
            "fieldname": "section_workflow",
            "label": "Statut & Approbation",
            "fieldtype": "Section Break"
        },
        {
            "fieldname": "statut",
            "label": "Statut",
            "fieldtype": "Select",
            "options": "Brouillon\nEn attente Chef\nEn attente Approbation\nEn attente DG\nApprouv\u00e9\nRejet\u00e9",
            "default": "Brouillon",
            "in_list_view": 1,
            "in_standard_filter": 1,
            "read_only": 1
        },
        {
            "fieldname": "col_wf",
            "fieldtype": "Column Break"
        },
        {
            "fieldname": "workflow_state",
            "label": "\u00c9tat du Flux",
            "fieldtype": "Data",
            "hidden": 1,
            "read_only": 1
        },
        {
            "fieldname": "amended_from",
            "label": "Modifi\u00e9 depuis",
            "fieldtype": "Link",
            "options": "Demande Achat KYA",
            "no_copy": 1,
            "print_hide": 1,
            "read_only": 1
        }
    ],
    "permissions": [
        {
            "role": "System Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "delete": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "HR Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1,
            "cancel": 1,
            "amend": 1
        },
        {
            "role": "Purchase Manager",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1,
            "cancel": 1
        },
        {
            "role": "Purchase User",
            "read": 1,
            "write": 1,
            "create": 1,
            "submit": 1
        },
        {
            "role": "Employee",
            "read": 1,
            "write": 1,
            "create": 1,
            "if_owner": 1
        }
    ]
}
