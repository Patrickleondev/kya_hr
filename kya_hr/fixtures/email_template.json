;border:1px solid #d0ead8;color:#222\">{{ from_date }}</td></tr>\n      <tr><td style=\"padding:9px 14px;background:#f0f8f4;border:1px solid #d0ead8;color:#555\">Date de fin</td><td style=\"padding:9px 14px;border:1px solid #d0ead8;color:#222\">{{ to_date }}</td></tr>\n      <tr><td style=\"padding:9px 14px;background:#f0f8f4;border:1px solid #d0ead8;color:#555\">Nombre de jours</td><td style=\"padding:9px 14px;border:1px solid #d0ead8;color:#222\">{{ total_leave_days }}</td></tr>\n      <tr><td style=\"padding:9px 14px;background:#f0f8f4;border:1px solid #d0ead8;color:#555\">Statut</td><td style=\"padding:9px 14px;border:1px solid #d0ead8\"><span style=\"background:#fff3cd;color:#856404;padding:2px 10px;border-radius:10px;font-size:12px;font-weight:600\">{{ workflow_state }}</span></td></tr>\n    </table>\n\n    {% set doc_link = frappe.utils.get_url_to_form('Leave Application', name) %}\n    <div style=\"text-align:center;margin:4px 0 20px\">\n      <a href=\"{{ doc_link }}\" target=\"_blank\" style=\"background:#1a6b4a;color:#ffffff;padding:12px 30px;border-radius:6px;text-decoration:none;font-size:14px;font-weight:600;display:inline-block\">→ Examiner la demande</a>\n    </div>\n  </td></tr>\n\n  <!-- FOOTER IMAGE (adresse + contacts) -->\n  <tr><td style=\"padding:0;border-top:2px solid #f0f0f0\">\n    <img src=\"{{ frappe.utils.get_url('/assets/kya_hr/images/image011.png') }}\" alt=\"KYA-Energy Group - Coordonnées\" style=\"width:100%;display:block\">\n  </td></tr>\n\n</table></td></tr></table></body></html>"
