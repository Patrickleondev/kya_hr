[
 {
  "name": "KYA-Energy Group",
  "doctype": "Letter Head",
  "letter_head_name": "KYA-Energy Group",
  "source": "HTML",
  "footer_source": "HTML",
  "disabled": 0,
  "is_default": 1,
  "image": null,
  "image_height": 0.0,
  "image_width": 0.0,
  "align": "Left",
  "content": "\n<style>\n    .kya-letterhead {\n        padding: 0;\n        margin: 0;\n        font-family: 'Helvetica Neue', Arial, sans-serif;\n    }\n    .kya-header-bar {\n        background: linear-gradient(135deg, #0d7377 0%, #0a5c5f 100%);\n        height: 6px;\n        width: 100%;\n        border-radius: 0 0 3px 3px;\n    }\n    .kya-header-table {\n        width: 100%;\n        border-collapse: collapse;\n        margin-top: 10px;\n        padding: 0 15px;\n    }\n    .kya-header-table td {\n        padding: 0 !important;\n        vertical-align: top;\n    }\n    .kya-logo-cell {\n        width: 65%;\n    }\n    .kya-company-name {\n        font-size: 22px;\n        font-weight: 700;\n        color: #0d7377;\n        letter-spacing: 0.5px;\n        margin-bottom: 2px;\n        line-height: 1.2;\n    }\n    .kya-company-slogan {\n        font-size: 10px;\n        color: #666;\n        font-style: italic;\n        margin-bottom: 6px;\n        letter-spacing: 0.3px;\n    }\n    .kya-company-address {\n        font-size: 9px;\n        color: #444;\n        line-height: 1.5;\n    }\n    .kya-doc-info {\n        text-align: right;\n        width: 35%;\n    }\n    .kya-doc-type {\n        font-size: 13px;\n        font-weight: 700;\n        color: #0d7377;\n        text-transform: uppercase;\n        letter-spacing: 1px;\n    }\n    .kya-doc-name {\n        font-size: 10px;\n        color: #888;\n        margin-top: 2px;\n    }\n    .kya-doc-date {\n        font-size: 9px;\n        color: #888;\n        margin-top: 4px;\n    }\n    .kya-contact-row {\n        font-size: 8.5px;\n        color: #555;\n    }\n    .kya-contact-row .label {\n        color: #0d7377;\n        font-weight: 600;\n        display: inline-block;\n        width: 50px;\n    }\n    .kya-header-divider {\n        border: none;\n        border-top: 1.5px solid #0d7377;\n        margin: 8px 0 0 0;\n        opacity: 0.4;\n    }\n</style>\n\n<div class=\"kya-letterhead\">\n    <div class=\"kya-header-bar\"></div>\n    <table class=\"kya-header-table\">\n        <tbody>\n            <tr>\n                <td class=\"kya-logo-cell\">\n                    {% set company_logo = frappe.db.get_value(\"Company\", doc.company, \"company_logo\") %}\n                    {% if company_logo %}\n                    <div style=\"margin-bottom: 6px;\">\n                        <img src=\"{{ frappe.utils.get_url(company_logo) }}\" style=\"max-height: 55px; max-width: 180px;\" />\n                    </div>\n                    {% endif %}\n                    <div class=\"kya-company-name\">KYA-Energy Group</div>\n                    <div class=\"kya-company-slogan\">Solutions \u00c9nerg\u00e9tiques Durables</div>\n                    <div class=\"kya-company-address\">\n                        {% set addr = frappe.db.get_value(\"Address\",\n                            {\"is_primary_address\": 1, \"link_doctype\": \"Company\", \"link_name\": doc.company},\n                            [\"address_line1\", \"address_line2\", \"city\", \"state\", \"pincode\", \"country\"],\n                            as_dict=True) or {} %}\n                        {% if addr.get(\"address_line1\") %}\n                            {{ addr.address_line1 or \"\" }}<br/>\n                            {% if addr.address_line2 %}{{ addr.address_line2 }}<br/>{% endif %}\n                            {{ addr.city or \"\" }}{% if addr.state %}, {{ addr.state }}{% endif %}\n                            {% if addr.pincode %} {{ addr.pincode }}{% endif %}<br/>\n                            {{ addr.country or \"Togo\" }}\n                        {% else %}\n                            Lom\u00e9, Togo\n                        {% endif %}\n                    </div>\n                </td>\n                <td class=\"kya-doc-info\">\n                    <div style=\"margin-top: 15px;\">\n                        <div class=\"kya-doc-type\">{{ _(doc.doctype) }}</div>\n                        <div class=\"kya-doc-name\">{{ doc.name }}</div>\n                        {% if doc.get(\"posting_date\") or doc.get(\"transaction_date\") %}\n                        <div class=\"kya-doc-date\">{{ frappe.format(doc.get(\"posting_date\") or doc.get(\"transaction_date\"), {\"fieldtype\": \"Date\"}) }}</div>\n                        {% endif %}\n                    </div>\n                    <div style=\"margin-top: 15px;\">\n                        {% set co = frappe.db.get_value(\"Company\", doc.company, [\"phone_no\", \"email\", \"website\"], as_dict=True) or {} %}\n                        {% if co.get(\"phone_no\") %}\n                        <div class=\"kya-contact-row\">\n                            <span class=\"label\">T\u00e9l :</span> {{ co.phone_no }}\n                        </div>\n                        {% endif %}\n                        {% if co.get(\"email\") %}\n                        <div class=\"kya-contact-row\">\n                            <span class=\"label\">Email :</span> {{ co.email }}\n                        </div>\n                        {% endif %}\n                        {% if co.get(\"website\") %}\n                        <div class=\"kya-contact-row\">\n                            <span class=\"label\">Web :</span> {{ co.website }}\n                        </div>\n                        {% endif %}\n                    </div>\n                </td>\n            </tr>\n        </tbody>\n    </table>\n    <hr class=\"kya-header-divider\" />\n</div>\n",
  "footer": "\n<style>\n    .kya-footer {\n        font-family: 'Helvetica Neue', Arial, sans-serif;\n        padding: 0;\n        margin: 0;\n    }\n    .kya-footer-divider {\n        border: none;\n        border-top: 1.5px solid #0d7377;\n        margin: 0 0 6px 0;\n        opacity: 0.4;\n    }\n    .kya-footer-table {\n        width: 100%;\n        border-collapse: collapse;\n    }\n    .kya-footer-table td {\n        padding: 0 8px !important;\n        vertical-align: top;\n        font-size: 7.5px;\n        color: #666;\n        line-height: 1.6;\n    }\n    .kya-footer-table .section-title {\n        font-weight: 700;\n        color: #0d7377;\n        font-size: 7.5px;\n        text-transform: uppercase;\n        letter-spacing: 0.5px;\n        margin-bottom: 1px;\n    }\n    .kya-footer-bar {\n        background: linear-gradient(135deg, #0d7377 0%, #0a5c5f 100%);\n        height: 4px;\n        width: 100%;\n        margin-top: 6px;\n        border-radius: 3px 3px 0 0;\n    }\n    .kya-footer-center {\n        text-align: center;\n        font-size: 7px;\n        color: #999;\n        margin-top: 4px;\n    }\n</style>\n\n<div class=\"kya-footer\">\n    <hr class=\"kya-footer-divider\" />\n    <table class=\"kya-footer-table\">\n        <tbody>\n            <tr>\n                <td style=\"width: 33%;\">\n                    <div class=\"section-title\">Si\u00e8ge Social</div>\n                    KYA-Energy Group<br/>\n                    Lom\u00e9, Togo<br/>\n                    T\u00e9l : +228 XX XX XX XX\n                </td>\n                <td style=\"width: 34%; text-align: center;\">\n                    <div class=\"section-title\">Informations L\u00e9gales</div>\n                    RCCM : TG-LOM-XXXX-X-XXXXX<br/>\n                    NIF : XXXXXXXXXX<br/>\n                    Capital : XXX.XXX.XXX XOF\n                </td>\n                <td style=\"width: 33%; text-align: right;\">\n                    <div class=\"section-title\">Coordonn\u00e9es Bancaires</div>\n                    Banque : XXXXXXXX<br/>\n                    Compte : XXXX XXXX XXXX XXXX<br/>\n                    Code SWIFT : XXXXXXXXXX\n                </td>\n            </tr>\n        </tbody>\n    </table>\n    <div class=\"kya-footer-bar\"></div>\n    <div class=\"kya-footer-center\">\n        KYA-Energy Group &mdash; Solutions \u00c9nerg\u00e9tiques Durables &mdash; www.kya-energy.com\n    </div>\n</div>\n",
  "footer_image": null,
  "footer_image_height": 0.0,
  "footer_image_width": 0.0,
  "footer_align": "Left",
  "header_script": null,
  "footer_script": null
 }
]
